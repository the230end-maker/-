# MongoDB connection string used by the backend server.
# Local MongoDB example:
MONGODB_URI=mongodb://localhost:27017

# MongoDB Atlas example:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/novel_writer?retryWrites=true&w=majority

# Optional backend port. Defaults to 8787.
PORT=8787

# Optional browser-only fallback shown for compatibility with src/lib/mongodb.ts.
# The app normally talks to MongoDB through the Express API, so most deployments do NOT need this.
# VITE_MONGODB_URI=mongodb://localhost:27017
